set number
set relativenumber
set shiftwidth=4
set tabstop=4
set expandtab
set nobackup
set nowrap
set incsearch
set smartcase
set showcmd
set showmode
set showmatch
set hlsearch
set history=1000
set nocompatible

filetype on
filetype plugin on
filetype indent on
syntax on

noremap <Space>pv :Exp<cr>
noremap <tab> <cmd>bNext<cr>
noremap <S-tab> <cmd>bprevious<cr>
